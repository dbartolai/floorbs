NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Legacy keys are also supported if you have not migrated yet:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Used to sign the simple scorer cookie.
SCORER_SESSION_SECRET=replace-with-a-long-random-string

# Local fallback demo scorer code when Supabase env vars are not configured.
DEMO_SCORER_CODE=123456
